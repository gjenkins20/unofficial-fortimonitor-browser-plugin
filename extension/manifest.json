{
  "manifest_version": 3,
  "name": "Unofficial FortiMonitor Toolkit",
  "short_name": "FM Toolkit",
  "description": "Session-authenticated tools for FortiMonitor - batch operations on port scope and more. Rides your existing FortiMonitor session; frontend-only, no API keys.",
  "version": "1.8.1",
  "author": "Gregori Jenkins",
  "homepage_url": "https://www.linkedin.com/in/gregorijenkins",
  "action": {
    "default_title": "Unofficial FortiMonitor Toolkit",
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "permissions": [
    "cookies",
    "storage",
    "alarms",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://fortimonitor.forticloud.com/*",
    "https://*.fortimonitor.com/*",
    "https://api2.panopta.com/*",
    "https://api.anthropic.com/*",
    "https://raw.githubusercontent.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://fortimonitor.forticloud.com/*",
        "https://*.fortimonitor.com/*"
      ],
      "js": ["src/content/augment.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://fortimonitor.forticloud.com/report/Instance/*",
        "https://*.fortimonitor.com/report/Instance/*"
      ],
      "js": ["src/content/template-edit-soft-refresh.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://fortimonitor.forticloud.com/*",
        "https://*.fortimonitor.com/*"
      ],
      "js": ["src/content/intro-tour-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/popup/popup.html",
        "src/ui/tenant-observations-diff/app.html"
      ],
      "matches": [
        "https://fortimonitor.forticloud.com/*",
        "https://*.fortimonitor.com/*"
      ]
    },
    {
      "resources": [
        "src/ui/intro-tour/tour-engine.js",
        "src/ui/intro-tour/step-renderer.js",
        "src/ui/intro-tour/step-schema.js",
        "src/ui/intro-tour/quiz.js",
        "src/ui/intro-tour/quiz-renderer.js",
        "src/ui/intro-tour/styles.css"
      ],
      "matches": [
        "https://fortimonitor.forticloud.com/*",
        "https://*.fortimonitor.com/*"
      ]
    },
    {
      "resources": [
        "src/lib/info-bubble-registry.js"
      ],
      "matches": [
        "https://fortimonitor.forticloud.com/*",
        "https://*.fortimonitor.com/*"
      ]
    }
  ]
}
