{
  "manifest_version": 3,
  "name": "Unofficial FortiMonitor Toolkit",
  "short_name": "FM Toolkit",
  "description": "Session-authenticated tools for FortiMonitor - batch operations on port scope and more. Rides your existing FortiMonitor session; frontend-only, no API keys.",
  "version": "0.7.0",
  "author": "Gregori Jenkins",
  "homepage_url": "https://www.linkedin.com/in/gregorijenkins",
  "action": {
    "default_title": "Unofficial FortiMonitor Toolkit",
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "permissions": [
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "https://fortimonitor.forticloud.com/*",
    "https://*.fortimonitor.com/*",
    "https://api2.panopta.com/*",
    "https://api.anthropic.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://fortimonitor.forticloud.com/*",
        "https://*.fortimonitor.com/*"
      ],
      "js": ["src/content/augment.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/popup/popup.html"],
      "matches": [
        "https://fortimonitor.forticloud.com/*",
        "https://*.fortimonitor.com/*"
      ]
    }
  ]
}
